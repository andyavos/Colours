{
  "name": "scss-colour-swatches",
  "version": "1.1.0",
  "description": "Compile SCSS from local or remote sources and generate a colour swatch reference page",
  "scripts": {
    "swatches": "node generate-swatches.js",
    "swatches:bootstrap": "node generate-swatches.js https://github.com/twbs/bootstrap --scss-subdir=scss --output=./bootstrap-swatches.html",
    "swatches:custom": "node generate-swatches.js ./src/styles ./dist/swatches.html"
  },
  "dependencies": {
    "sass": "^1.77.0"
  }
}
